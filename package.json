{
  "name": "@sendmator/node",
  "version": "0.0.3",
  "description": "Official Node.js SDK for Sendmator - Multi-channel messaging API (Email, SMS, WhatsApp, Push Notifications, OTP)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "version": "npm run build && git add -A dist",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "sendmator",
    "email",
    "sms",
    "whatsapp",
    "push-notifications",
    "fcm",
    "apns",
    "firebase",
    "otp",
    "messaging",
    "notifications",
    "transactional-email",
    "api-client",
    "sdk",
    "contact-management",
    "preference-center",
    "device-tokens"
  ],
  "author": "Sendmator Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sendmator/sendmator-node"
  },
  "bugs": {
    "url": "https://github.com/sendmator/sendmator-node/issues"
  },
  "homepage": "https://docs.sendmator.com",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  }
}
